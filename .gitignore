# =============================================================================
# Security Management Platform (SMP) — .gitignore
# =============================================================================

# ─── Sensitive / Personal Data ───────────────────────────────────────────────
config/settings.json          # Contains SMTP credentials — NEVER commit
database/security.db          # SQLite database — local only
database/*.db
way.md                        # Personal developer diary & comprehensive logs
task.md                       # Local planning artifact
walkthrough.md                # Local planning artifact
implementation_plan.md        # Local planning artifact

# ─── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log

# ─── Reports (generated output) ──────────────────────────────────────────────
reports/html/
reports/pdf/
reports/**/*.html
reports/**/*.pdf

# ─── Intel Cache ─────────────────────────────────────────────────────────────
cache/intel_cache.json

# ─── Python Virtual Environment ──────────────────────────────────────────────
venv/
.venv/
env/
.env/
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python

# ─── Project-local Binaries ──────────────────────────────────────────────────
bin/
*.exe
*.bin

# ─── OS / IDE Artifacts ──────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini
.idea/
*.swp
*.swo
*~

# ─── VS Code (keep launch.json for dev convenience, ignore workspace) ─────────
.vscode/*.code-workspace
.vscode/settings.json

# ─── Temporary Files ─────────────────────────────────────────────────────────
*.tmp
*.temp
ffuf_out_*.json
/tmp/

# ─── Build / Distribution ────────────────────────────────────────────────────
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/
site/

# ─── Test Artifacts ──────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
